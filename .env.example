# ─── Banco ──────────────────────────────────────────────────────────────
# Em branco => usa SQLite local (canavis.db) — ótimo para rodar sem Supabase.
# Para Supabase, use a connection string "pooler" (porta 6543) de leitura/escrita:
# DATABASE_URL=postgresql+psycopg://USER:SENHA@HOST:6543/postgres
DATABASE_URL=

# Credencial somente-leitura usada pelo app Streamlit (opcional; cai no DATABASE_URL).
DATABASE_URL_RO=

# ─── E-mail diário (Resend) ─────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=relatorio@seu-dominio-verificado.com
EMAIL_TEST_RECIPIENT=voce@exemplo.com

# ─── Resumo de notícias ─────────────────────────────────────────────────
# extractive (padrão, sem custo) | llm (plugue opcional, exige chave abaixo)
SUMMARY_PROVIDER=extractive
SUMMARY_API_KEY=

# ─── Geral ──────────────────────────────────────────────────────────────
TIMEZONE=America/Sao_Paulo
ENV=local
